# Required by src/config.py

# Path to SQLite database file.
# Local example: src/data/db/bot.db
# Docker/deploy example: /app/src/data/db/bot.db
BOT_DB_PATH=src/data/db/bot.db

# Р”РёСЂРµРєС‚РѕСЂРёСЏ РґР»СЏ РІСЂРµРјРµРЅРЅС‹С… Р·Р°РіСЂСѓР¶РµРЅРЅС‹С… С„Р°Р№Р»РѕРІ.
# Runtime СЃРѕР·РґР°РµС‚ СЌС‚Сѓ РґРёСЂРµРєС‚РѕСЂРёСЋ Рё РїРѕРґРґРёСЂРµРєС‚РѕСЂРёРё РїРѕ handler-РєР»Р°СЃСЃР°Рј Р°РІС‚РѕРјР°С‚РёС‡РµСЃРєРё.
# Р›РѕРєР°Р»СЊРЅС‹Р№ РїСЂРёРјРµСЂ: src/data/runtime (РёР»Рё РѕСЃС‚Р°РІСЊ РїСѓСЃС‚С‹Рј РґР»СЏ Р·РЅР°С‡РµРЅРёСЏ РїРѕ СѓРјРѕР»С‡Р°РЅРёСЋ)
# Docker/deploy РїСЂРёРјРµСЂ: /tmp/djgurda/runtime
BOT_TEMP_DIR=

# Shown in /info command
BOT_VERSION=local-dev

# Telegram user ID of bot administrator (must be integer)
ADMIN_ID=123456789

# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Yandex Music token (required by current config validation)
YANDEX_MUSIC_TOKEN=your_yandex_music_token_here

# Base directory for cookies files.
# If provider-specific *_COOKIES_PATH is empty, file is auto-resolved from this directory:
# - www.youtube.com_cookies.txt
# - instagram_cookies.txt
# - vk.com_cookies.txt
# Local source (РѕСЂРёРіРёРЅР°Р»С‹): local/cookies
# Local runtime/workdir: src/data/cookies
# Docker/deploy example: /app/src/data/cookies
COOKIES_DIR=src/data/cookies

# Enable cookies for YouTube extractor (true/false).
# By default valid cookies are used automatically; placeholder file is ignored.
# Р”Р»СЏ yt-dlp РёСЃРїРѕР»СЊР·СѓРµС‚СЃСЏ РІСЂРµРјРµРЅРЅР°СЏ СЂР°Р±РѕС‡Р°СЏ РєРѕРїРёСЏ cookie-С„Р°Р№Р»Р°, РѕСЂРёРіРёРЅР°Р» РЅРµ РјРѕРґРёС„РёС†РёСЂСѓРµС‚СЃСЏ.
YOUTUBE_COOKIES_ENABLED=true

# Optional explicit path to YouTube cookies file.
# Leave empty to use COOKIES_DIR/www.youtube.com_cookies.txt.
YOUTUBE_COOKIES_PATH=

# Enable cookies for Instagram extractor (true/false).
# Stories often require authenticated cookies.
# Р”Р»СЏ yt-dlp РёСЃРїРѕР»СЊР·СѓРµС‚СЃСЏ РІСЂРµРјРµРЅРЅР°СЏ СЂР°Р±РѕС‡Р°СЏ РєРѕРїРёСЏ cookie-С„Р°Р№Р»Р°, РѕСЂРёРіРёРЅР°Р» РЅРµ РјРѕРґРёС„РёС†РёСЂСѓРµС‚СЃСЏ.
INSTAGRAM_COOKIES_ENABLED=true

# Optional explicit path to Instagram cookies file.
# Leave empty to use COOKIES_DIR/instagram_cookies.txt.
INSTAGRAM_COOKIES_PATH=

# Enable cookies for TikTok extractor (true/false).
# For yt-dlp uses a temporary runtime copy; original file is not modified.
TIKTOK_COOKIES_ENABLED=true

# Optional explicit path to TikTok cookies file.
# Leave empty to use COOKIES_DIR/tiktok_cookies.txt.
TIKTOK_COOKIES_PATH=

# Enable cookies for VK extractor (true/false).
# VK music extraction may require an authenticated session.
# Р”Р»СЏ yt-dlp РёСЃРїРѕР»СЊР·СѓРµС‚СЃСЏ РІСЂРµРјРµРЅРЅР°СЏ СЂР°Р±РѕС‡Р°СЏ РєРѕРїРёСЏ cookie-С„Р°Р№Р»Р°, РѕСЂРёРіРёРЅР°Р» РЅРµ РјРѕРґРёС„РёС†РёСЂСѓРµС‚СЃСЏ.
VK_COOKIES_ENABLED=true

# Optional explicit path to VK cookies file (Netscape format).
# Leave empty to use COOKIES_DIR/vk.com_cookies.txt.
VK_COOKIES_PATH=


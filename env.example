# Обязательные переменные, валидируемые в src/config.py.

# Путь до SQLite-базы.
# Локальный пример: src/data/db/bot.db
# Docker/deploy пример: /app/src/data/db/bot.db
BOT_DB_PATH=src/data/db/bot.db

# Runtime-директория временных файлов фиксирована в config.py: /app/src/data/runtime внутри контейнера.
# Для локального запуска относительный путь эквивалентен src/data/runtime.

# Показывается в команде /info.
BOT_VERSION=local-dev

# Telegram user ID администратора бота (целое число).
ADMIN_ID=123456789

# Telegram bot token из @BotFather.
BOT_TOKEN=your_telegram_bot_token_here

# Yandex Music token (требуется текущей валидацией config).
YANDEX_MUSIC_TOKEN=your_yandex_music_token_here

# Базовая директория cookies-файлов.
# Если provider-specific *_COOKIES_PATH пуст, файл автоматически ищется в этой директории:
# - www.youtube.com_cookies.txt
# - instagram_cookies.txt
# - tiktok_cookies.txt
# - vk.com_cookies.txt
# Локальный источник оригиналов: local/cookies
# Локальный runtime/workdir: src/data/cookies
# Docker/deploy пример: /app/src/data/cookies
COOKIES_DIR=src/data/cookies

# Включить cookies для YouTube extractor (true/false).
# По умолчанию валидные cookies используются автоматически; placeholder-файл игнорируется.
# Для yt-dlp используется временная runtime-копия cookie-файла; оригинал не модифицируется.
YOUTUBE_COOKIES_ENABLED=true

# Необязательный явный путь к YouTube cookies-файлу.
# Оставь пустым, чтобы использовать COOKIES_DIR/www.youtube.com_cookies.txt.
YOUTUBE_COOKIES_PATH=

# Включить cookies для Instagram extractor (true/false).
# Stories часто требуют авторизованные cookies.
# Для yt-dlp используется временная runtime-копия cookie-файла; оригинал не модифицируется.
INSTAGRAM_COOKIES_ENABLED=true

# Необязательный явный путь к Instagram cookies-файлу.
# Оставь пустым, чтобы использовать COOKIES_DIR/instagram_cookies.txt.
INSTAGRAM_COOKIES_PATH=

# Включить cookies для TikTok extractor (true/false).
# Для yt-dlp используется временная runtime-копия; оригинальный файл не модифицируется.
TIKTOK_COOKIES_ENABLED=true

# Необязательный явный путь к TikTok cookies-файлу.
# Оставь пустым, чтобы использовать COOKIES_DIR/tiktok_cookies.txt.
TIKTOK_COOKIES_PATH=

# Включить cookies для VK extractor (true/false).
# VK music extraction может требовать авторизованную сессию.
# Для yt-dlp используется временная runtime-копия cookie-файла; оригинал не модифицируется.
VK_COOKIES_ENABLED=true

# Необязательный явный путь к VK cookies-файлу (формат Netscape).
# Оставь пустым, чтобы использовать COOKIES_DIR/vk.com_cookies.txt.
VK_COOKIES_PATH=
